{
  "name": "tailwind3-scale",
  "version": "1.2.0",
  "description": "Tailwind CSS v3 移动端适配插件，基于设计稿像素的等比缩放方案，兼容 iOS 13",
  "keywords": [
    "tailwindcss",
    "tailwind",
    "tailwindcss-plugin",
    "mobile",
    "scale",
    "responsive",
    "ios13"
  ],
  "license": "MIT",
  "author": "ldystudio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ldystudio/tailwind3-scale.git"
  },
  "main": "./dist/plugin.cjs",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "require": "./dist/plugin.cjs",
      "default": "./dist/plugin.cjs"
    },
    "./js": {
      "types": "./dist/scale.d.ts",
      "require": "./dist/scale.cjs",
      "import": "./dist/scale.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown -c && bun scripts/copy-types.ts",
    "test": "bun test",
    "lint": "biome lint --write .",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "bun check && bun test && bun run build"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0 <4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.8",
    "rolldown": "^1.0.2",
    "tailwindcss": "^3.4.17"
  }
}
